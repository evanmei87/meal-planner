# --- Python Base ---
__pycache__/
*.py[cod]
*$py.class
*.so

# --- Environments (Crucial for uv) ---
.venv/
venv/
ENV/

# --- Tools & Caches ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# --- Tool Managers (mise) ---
# Keep your main .tool-versions or mise.toml, but ignore local user overrides
.mise.local.toml
.mise.local.*

# --- IDEs and OS Garbage ---
.vscode/
.idea/
.DS_Store
Thumbs.db

# --- Security & State ---
.env
state.json

# --- Project-Specific Runtime State ---
# This prevents your personal history/session state from causing Git conflicts
src/state/
src/data/user_stats.csv

# --- Frontend ---
web/node_modules/
web/dist/
web/.env
